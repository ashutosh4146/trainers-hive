modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 60000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3001

[[ports]]
localPort = 8083
externalPort = 3002

[[ports]]
localPort = 23629
externalPort = 3000

[userenv]

[userenv.shared]
VITE_FIREBASE_API_KEY = "AIzaSyC3m1IZj4o8Xgjy6z7M5rQpiFKrfmhS_do"
VITE_FIREBASE_APP_ID = "1:491480752528:web:f3035c483319531a3ed315"
VITE_FIREBASE_MESSAGING_SENDER_ID = "491480752528"

[userenv.production]
APP_DOMAIN = "trainershive.com"

[nix]
channel = "stable-25_05"
